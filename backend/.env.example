# CabinConnect API — Environment Variables
# Copy this file to .env and populate all values. Never commit .env.

# API listen address
ASPNETCORE_URLS=http://localhost:5000

# Allowed CORS origins — comma-separated, no trailing slashes
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Supabase JWT secret — Settings → API → JWT Secret (added in Unit 2)
# SUPABASE_JWT_SECRET=

# PostgreSQL connection string — Settings → Database → Connection string
# Use keyword format with SSL Mode=Require (added in Unit 3)
# DATABASE_URL=Host=...;Port=5432;Database=postgres;Username=postgres;Password=...;SSL Mode=Require
